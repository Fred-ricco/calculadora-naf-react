generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id          String    @id @default(cuid())
  nome        String
  email       String    @unique
  senha       String
  createdAt   DateTime  @default(now())

  calculos    HistoricoCalculo[]
}

model HistoricoCalculo {
  id           String   @id @default(cuid())
  profissao    String
  renda        Float
  custos       Float
  resultadoPF  Json
  resultadoPJ  Json
  economia     Float

  usuarioId    String
  usuario      Usuario @relation(fields: [usuarioId], references: [id])

  createdAt    DateTime @default(now())
}